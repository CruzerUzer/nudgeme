# NudgeMe-server – miljövariabler. Kopiera till .env vid behov.

# Port servern lyssnar på (allokeras via Helm: helmctl port claim nudgeme-server).
PORT=4303

# Hemlighet för JWT-signering. SÄTT ETT EGET, LÅNGT VÄRDE I PRODUKTION!
JWT_SECRET=byt-mig-till-nagot-langt-och-hemligt

# Sökväg till SQLite-filen (default: server/data/nudgeme.db).
NUDGEME_DB=

# Hur ofta nudge-motorn körs, i millisekunder (default 60000 = 1 min).
# Sänk vid testning för snabbare aktiviteter, t.ex. TICK_MS=5000.
TICK_MS=

# Web Push (VAPID) – valfritt, för push-notiser.
# Generera par med:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:du@exempel.se
