{
  "name": "nudgeme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "En snäll app som viskar fram roliga aktiviteter du annars glömmer bort.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
