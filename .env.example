# NudgeMe miljövariabler
# Kopiera till .env.local och fyll i. Utan dessa körs appen i LOKALT läge
# (data i webbläsarens localStorage, inga riktiga konton eller push).

# --- Lokal server (multi-user utan Supabase) ---
# Sätt till serverns adress så byter appen till inloggning + SQLite-backend.
# Har högst prioritet (går före Supabase nedan). Måste vara nåbar från klienten
# (t.ex. Tailscale-URL om du testar från telefonen).
VITE_API_URL=

# Supabase — skapa ett gratisprojekt på https://supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (VAPID) — publik nyckel exponeras i klienten.
# Generera par med:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Datakälla: "local" (default utan Supabase) eller "supabase"
VITE_DATA_SOURCE=local
