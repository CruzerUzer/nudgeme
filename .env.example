# NudgeMe – frontend-miljövariabler
# Kopiera till .env.local och fyll i vid behov.

# Lokal server (multi-user). Sätt till serverns adress så byter appen till
# inloggning + SQLite-backend. Lämna tom för LOKALT läge (data i webbläsarens
# localStorage/IndexedDB, en automatisk gäst, ingen inloggning).
# Måste vara nåbar från klienten – använd Tailscale-URL om du testar från
# telefonen, t.ex. http://hemmalinux.taila35f69.ts.net:4303
VITE_API_URL=

# Web Push (VAPID) – publik nyckel (valfritt, för push-notiser).
# Generera par med:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
